/* ===== PRODUCTS SECTION ===== */
.products-section {
    padding: 100px 0;
    background: var(--light-color);
    position: relative;
    overflow: hidden;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-subtitle {
    display: inline-block;
    padding: 8px 20px;
    background: var(--primary-extra-light);
    color: var(--primary-color);
    border-radius: var(--radius-xl);
    font-weight: 500;
    margin-bottom: 15px;
}

.section-title {
    font-family: var(--font-titr);
    font-size: 2.5rem;
    color: var(--dark-color);
    margin-bottom: 20px;
    position: relative;
    display: inline-block;
}

.section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background: var(--primary-color);
    border-radius: 2px;
}

.section-description {
    max-width: 600px;
    margin: 0 auto;
    color: var(--gray-dark);
    line-height: 1.6;
}

.products-filter {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 40px;
    flex-wrap: wrap;
}

.filter-btn {
    padding: 12px 28px;
    background: transparent;
    border: 2px solid var(--gray-light);
    color: var(--gray-dark);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-normal);
    font-family: 'Vazirmatn', sans-serif;
    font-weight: 600;
    font-size: 1rem;
}

.filter-btn:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
    transform: translateY(-2px);
}

.filter-btn.active {
    background: var(--primary-color);
    border-color: var(--primary-color);
    color: var(--white);
    box-shadow: var(--shadow-primary);
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    margin-bottom: 50px;
}

.product-card {
    perspective: 1000px;
    background: transparent !important;
    box-shadow: none !important;
    overflow: visible !important;
    transition: height 0.2s ease;
}

.product-card[data-window-card="true"] {
    display: none;
}

.product-flipper {
    transition: transform 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    transform-style: preserve-3d;
    position: relative;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    background: transparent;
}

.product-front,
.product-back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.product-front {
    position: relative;
    width: 100%;
    min-height: 460px;
    background-color: var(--white);
    display: flex;
    flex-direction: column;
}

.product-back {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 460px;
    height: 100%;
    transform: rotateY(180deg);
    background-color: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 30px 25px;
    box-sizing: border-box;
    overflow: auto;
}

.product-image {
    position: relative;
    overflow: hidden;
    height: 240px;
    flex-shrink: 0;
}

.product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.product-card:hover .product-img {
    transform: scale(1.05);
}

.product-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-normal);
}

.product-card:hover .product-overlay {
    opacity: 1;
}

.quick-view-btn {
    padding: 12px 24px;
    background: var(--white);
    color: var(--primary-color);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-weight: 600;
    transform: translateY(20px);
    transition: all var(--transition-normal);
}

.product-card:hover .quick-view-btn {
    transform: translateY(0);
}

.quick-view-btn:hover {
    background: var(--primary-color);
    color: var(--white);
}

.product-content {
    padding: 25px;
}

.product-category {
    display: inline-block;
    color: var(--primary-color);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
}

.product-title {
    font-family: var(--font-titr);
    font-size: 1.25rem;
    color: var(--dark-color);
    margin-bottom: 10px;
    transition: color var(--transition-fast);
    padding: 0 20px;
}

.product-title.product-title--small {
    font-size: 1.1rem;
}

.product-title a {
    color: inherit;
    text-decoration: none;
}

.product-card:hover .product-title {
    color: var(--primary-color);
}

.product-description {
    color: var(--gray-dark);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 20px;
}

.product-separator {
    width: calc(100% - 40px);
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--primary-light) 20%, var(--primary-color) 50%, var(--primary-light) 80%, transparent 100%);
    margin: 12px auto 8px auto;
    border-radius: 2px;
    flex-shrink: 0;
}

.product-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: auto;
}

.btn-details {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: transparent;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all var(--transition-normal);
    cursor: pointer;
}

.btn-details:hover {
    background: var(--primary-color);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-primary);
}

.product-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    padding: 6px 12px;
    background: var(--secondary-color);
    color: var(--white);
    border-radius: var(--radius-md);
    font-size: 12px;
    font-weight: 600;
    z-index: 10;
}

.product-card:hover .product-flipper {
    transform: rotateY(180deg);
}

.product-featured {
    grid-column: span 2;
}

.view-all-container {
    text-align: center;
    margin-top: 50px;
}

.view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 40px;
    background: transparent;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-normal);
}

.view-all-btn:hover {
    background: var(--primary-color);
    color: var(--white);
    transform: translateY(-3px);
    box-shadow: var(--shadow-primary);
}

.view-all-icon {
    transition: transform var(--transition-normal);
}

.view-all-btn:hover .view-all-icon {
    transform: translateX(5px);
}

.mixitup-container {
    position: relative;
    min-height: 500px;
}

.mix {
    display: none;
}

@media (max-width: 1024px) {
    .products-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 768px) {
    .products-filter {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        justify-content: flex-start;
        gap: 10px;
        padding: 10px 15px 15px;
        margin: 0 -15px 30px -15px;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
        scroll-snap-type: x mandatory;
    }

    .products-filter::-webkit-scrollbar {
        height: 4px;
    }

    .products-filter::-webkit-scrollbar-track {
        background: var(--gray-light);
        border-radius: 10px;
    }

    .products-filter::-webkit-scrollbar-thumb {
        background: var(--primary-color);
        border-radius: 10px;
    }

    .filter-btn {
        flex-shrink: 0;
        padding: 8px 18px;
        font-size: 0.8rem;
        white-space: nowrap;
        scroll-snap-align: start;
    }

    .products-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    .product-card {
        margin-bottom: 0;
        min-height: 220px;
    }

    .product-front,
    .product-back {
        min-height: 380px;
    }

    .product-image {
        height: 150px;
    }

    .product-content {
        padding: 12px;
    }

    .product-title {
        font-size: 0.9rem;
        margin-bottom: 5px;
        padding: 0 12px;
    }

    .product-title.product-title--small {
        font-size: 0.9rem;
    }

    .product-description {
        font-size: 0.7rem;
        margin-bottom: 10px;
    }

    .product-category {
        font-size: 0.65rem;
        margin-bottom: 5px;
    }

    .product-separator {
        width: calc(100% - 24px);
        margin: 8px auto 6px auto;
    }

    .product-back {
        padding: 20px 15px;
    }

    .product-back .product-description {
        font-size: 0.8rem;
        margin-bottom: 15px;
    }

    .product-footer {
        padding-top: 10px;
        margin-top: 10px;
    }

    .btn-details {
        padding: 6px 12px;
        font-size: 0.7rem;
        gap: 4px;
    }

    .btn-details svg {
        width: 12px;
        height: 12px;
    }

    .product-badge {
        top: 8px;
        left: 8px;
        padding: 3px 8px;
        font-size: 0.6rem;
    }

    .product-overlay {
        display: none;
    }

    .section-title {
        font-size: 1.8rem;
    }

    .section-description {
        font-size: 0.9rem;
    }

    .product-card .product-flipper {
        transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }
}

@media (max-width: 580px) {
    .products-filter {
        padding: 8px 12px 12px;
        margin: 0 -12px 25px -12px;
        gap: 8px;
    }

    .filter-btn {
        padding: 6px 14px;
        font-size: 0.75rem;
    }

    .products-grid {
        gap: 10px;
    }

    .product-image {
        height: 130px;
    }
}

@media (max-width: 480px) {
    .products-filter {
        padding: 6px 10px 10px;
        margin: 0 -10px 20px -10px;
        gap: 6px;
    }

    .filter-btn {
        padding: 6px 12px;
        font-size: 0.7rem;
    }

    .products-grid {
        gap: 8px;
    }

    .product-front,
    .product-back {
        min-height: 340px;
    }

    .product-image {
        height: 120px;
    }

    .product-title {
        font-size: 0.8rem;
    }

    .product-back {
        padding: 15px 12px;
    }

    .product-back .product-description {
        font-size: 0.7rem;
        margin-bottom: 12px;
    }

    .btn-details {
        padding: 5px 8px;
        font-size: 0.65rem;
    }

    .product-separator {
        margin: 6px auto 4px auto;
    }

    .product-title.product-title--small {
        font-size: 0.8rem !important;
        font-weight: 600;
    }
}